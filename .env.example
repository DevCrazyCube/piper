# Copy to .env and fill real values. .env is gitignored — NEVER commit secrets.

# --- Database (the docker-compose 'db' service) ---
AEGIS_DB_HOST=db
AEGIS_DB_PORT=5432
AEGIS_DB_NAME=aegis
AEGIS_DB_USER=aegis
AEGIS_DB_PASSWORD=change-me-strong-password

# --- Application-layer encryption (ADR-0008) ---
# 32-byte AES-256 key, base64-encoded. Generate one with:
#   python -c "import os,base64;print(base64.b64encode(os.urandom(32)).decode())"
# This key NEVER goes in the database and NEVER gets committed.
AEGIS_MASTER_KEY=

# --- Misc ---
AEGIS_DATASETS_DIR=/data/datasets
AEGIS_LOG_LEVEL=INFO

# --- Runtime app role (non-superuser; RLS applies). Set then run `make bootstrap`. ---
AEGIS_APP_USER=aegis_app
AEGIS_APP_PASSWORD=change-me-app-password
